rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Problems are read-only to signed-in users. Writes come from the
    // generator via the Admin SDK, which bypasses these rules entirely, so
    // client writes are simply denied.
    match /problems/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // The lightweight pool index (meta/index) the app reads to build its
    // problem list + filters. Read-only to clients; written by the Admin SDK.
    match /meta/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Each user owns their measurement stream and profile: read/write only
    // your own subtree. The {doc=**} wildcard is required — subcollection
    // rules do NOT cascade without it.
    match /users/{uid}/{doc=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
