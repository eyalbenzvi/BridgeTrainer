rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Problems are read-only to signed-in users, and only ONE AT A TIME by id.
    // `get` (single doc) is allowed; `list` (collection query) is denied, so a
    // client cannot run getDocs(collection("problems")) and read the whole
    // pool (~20k docs = 20k reads) in one call — that would let any signed-in
    // Google account drain the shared free-tier read quota. The app never
    // lists problems: it reads meta/index and then fetches problems by id.
    // Writes come from the generator via the Admin SDK, which bypasses rules.
    match /problems/{id} {
      allow get: if request.auth != null;
      allow list: if false;
      allow write: if false;
    }

    // The lightweight, sharded pool index (meta/index + meta/index_shard_*)
    // the app reads to build its problem list + filters. Single-doc reads
    // only (the client reads the pointer then each shard by id); listing the
    // meta collection is denied. Written by the Admin SDK.
    match /meta/{doc} {
      allow get: if request.auth != null;
      allow list: if false;
      allow write: if false;
    }

    function owner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Schema + size validation for an attempt document. The previous rule used
    // request.resource.size() — NOT a valid API (Resource has no size()), so
    // the whole condition failed to evaluate. Use request.resource.data.size()
    // (a FIELD count) with an explicit key allowlist and string/list caps to
    // bound the document without relying on a byte measure the language does
    // not offer. The allowlist is the union of every field the web client
    // writes: web/bt-firebase.js meta()+gradeBidding()+gradeLead()+record().
    function validAttempt() {
      let d = request.resource.data;
      return d.size() < 25
        && d.keys().hasOnly([
          'problemId', 'problemVersion', 'scoringForm', 'kind', 'type',
          'difficultyLevel', 'answer', 'chosenCall', 'correct', 'outcomeClass',
          'gradedCost', 'score', 'acceptedSet', 'trainingMode', 'rankingMetric',
          'chosenRank', 'recommendedLead', 'primaryValue', 'isFirstAttempt',
          'attemptCount', 'ts', 'lastTs'])
        // type-check only the fields that are never null; the rest may be
        // null/absent (see meta()/gradeLead), so don't force a type on them.
        && d.answer is string && d.answer.size() < 16
        && d.score is number
        && d.correct is bool
        && d.attemptCount is int
        && (!('acceptedSet' in d) || d.acceptedSet.size() < 40)
        && (!('chosenCall' in d) || (d.chosenCall is string
              && d.chosenCall.size() < 16));
    }

    // Each user owns their own data: read/write only your own subtree. Only the
    // top-level user doc (a future profile) and the attempts stream are
    // writable; attempts are schema-validated (validAttempt). No recursive
    // {doc=**} write rule, so a client can't create arbitrary subcollections.
    match /users/{uid} {
      allow read: if owner(uid);
      allow write: if owner(uid) && request.resource.data.size() < 50;

      match /attempts/{pid} {
        allow read: if owner(uid);
        allow write: if owner(uid) && validAttempt();
      }
    }
  }
}
