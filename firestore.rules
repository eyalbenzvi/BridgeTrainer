rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Problems are read-only to signed-in users, and only ONE AT A TIME by id.
    // `get` (single doc) is allowed; `list` (collection query) is denied, so a
    // client cannot run getDocs(collection("problems")) and read the whole
    // pool (~20k docs = 20k reads) in one call — that would let any signed-in
    // Google account drain the shared free-tier read quota. The app never
    // lists problems: it reads meta/index and then fetches problems by id.
    // Writes come from the generator via the Admin SDK, which bypasses rules.
    match /problems/{id} {
      allow get: if request.auth != null;
      allow list: if false;
      allow write: if false;
    }

    // The lightweight, sharded pool index (meta/index + meta/index_shard_*)
    // the app reads to build its problem list + filters. Single-doc reads
    // only (the client reads the pointer then each shard by id); listing the
    // meta collection is denied. Written by the Admin SDK.
    match /meta/{doc} {
      allow get: if request.auth != null;
      allow list: if false;
      allow write: if false;
    }

    function owner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // The allowlist of attempt fields: the union of everything the web client
    // writes (web/bt-firebase.js meta()+gradeBidding()+gradeLead()+record()).
    function attemptKeys() {
      return [
        'problemId', 'problemVersion', 'scoringForm', 'kind', 'type',
        'difficultyLevel', 'answer', 'chosenCall', 'correct', 'outcomeClass',
        'gradedCost', 'score', 'acceptedSet', 'trainingMode', 'rankingMetric',
        'chosenRank', 'recommendedLead', 'primaryValue', 'isFirstAttempt',
        'attemptCount', 'ts', 'firstTs', 'lastTs'];
    }

    // Structural bounds shared by create and update: a field-count cap and the
    // key allowlist. The previous rule used request.resource.size() — NOT a
    // valid API (Resource has no size()), so the whole condition failed to
    // evaluate; use request.resource.data.size() (a FIELD count) plus explicit
    // caps instead, since the language offers no byte measure.
    function attemptBounds(d) {
      return d.size() < 25 && d.keys().hasOnly(attemptKeys())
        && d.attemptCount is int
        && (!('acceptedSet' in d) || d.acceptedSet.size() < 40)
        && (!('answer' in d) || (d.answer is string && d.answer.size() < 16))
        && (!('chosenCall' in d) || (d.chosenCall is string
              && d.chosenCall.size() < 16))
        && (!('score' in d) || d.score is number)
        && (!('correct' in d) || d.correct is bool);
    }

    // A fresh (first-attempt) doc from the current client always carries the
    // full grading, so create requires score/answer/correct.
    function validCreate() {
      let d = request.resource.data;
      return attemptBounds(d)
        && d.answer is string && d.score is number && d.correct is bool;
    }

    // A re-answer is a merge write ({attemptCount, lastTs}); the MERGED doc is
    // validated. LEGACY docs predate the panel `score` field, so update must
    // NOT require it (type-checks are presence-conditional in attemptBounds) —
    // otherwise re-answering an old problem would be rejected. Structural
    // bounds (field count, key allowlist, attemptCount:int) still apply.
    function validUpdate() {
      return attemptBounds(request.resource.data);
    }

    // Each user owns their own data: read only your own subtree. The ONLY
    // writable location is the schema-validated attempts stream — no client
    // writes the top-level user doc (the "profile" was documented but never
    // implemented, SEC-A-6/DB-M-9), and there is no recursive {doc=**} write
    // rule, so a client cannot create arbitrary docs or subcollections.
    match /users/{uid} {
      allow read: if owner(uid);

      match /attempts/{pid} {
        allow read: if owner(uid);
        allow create: if owner(uid) && validCreate();
        allow update: if owner(uid) && validUpdate();
      }
    }
  }
}
